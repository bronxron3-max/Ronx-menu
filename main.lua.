RunService.RenderStepped:Connect(function()
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local lp = Players.LocalPlayer
    
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        lp.Character.Humanoid.WalkSpeed = _G.WalkSpeed
        if _G.AirWalkEnabled and lp.Character:FindFirstChild("HumanoidRootPart") then
            AirPart.CanCollide = true
            AirPart.CFrame = lp.Character.HumanoidRootPart.CFrame * CFrame.new(0, -3.5, 0)
        end
    end

    if _G.FullBright then game:GetService("Lighting").Ambient = Color3.new(1,1,1) end
    if _G.AimbotEnabled then
        local t = getClosestToCenter()
        if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, t.Position), _G.AimbotSmoothing) end
    end
    if _G.EspEnabled and ZombieFolder then
        for _, z in pairs(ZombieFolder:GetChildren()) do createESP(z) end
    elseif not _G.EspEnabled and ZombieFolder then
        for _, z in pairs(ZombieFolder:GetChildren()) do
            if z:FindFirstChild("Head") and z.Head:FindFirstChild("RX_ESP") then z.Head.RX_ESP:Destroy() end
        end
    end
end)

