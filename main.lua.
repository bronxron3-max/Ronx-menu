-- // 2. DATA STORAGE (ANTI-ILANG)
local Waypoints = {}

local function SaveToFile()
    pcall(function()
        local t = {}
        for name, cf in pairs(Waypoints) do t[name] = {cf.X, cf.Y, cf.Z} end
        writefile(FileName, HttpService:JSONEncode(t))
    end)
end

local function LoadFromFile()
    if isfile(FileName) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(FileName))
            for name, pos in pairs(decoded) do Waypoints[name] = CFrame.new(pos[1], pos[2], pos[3]) end
        end)
    end
end
