local function getLaper()
    local p = Players.LocalPlayer
    local h = 100
    local g = p.PlayerGui:FindFirstChild("HungerSprintUI", true)
    if g then
        for _, v in pairs(g:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text:match("%d+") then h = tonumber(v.Text:match("%d+")) break end
        end
    end
    return h
end

local function getClosestToCenter()
    local target, shortestDist = nil, _G.FOVRadius
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    if ZombieFolder then
        for _, zombi in pairs(ZombieFolder:GetChildren()) do
            local head = zombi:FindFirstChild("Head")
            if head and zombi:FindFirstChildOfClass("Humanoid") and zombi.Humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    if dist < shortestDist then target = head shortestDist = dist end
                end
            end
        end
    end
    return target
end

local function createESP(v)
    if v:FindFirstChild("Head") and not v.Head:FindFirstChild("RX_ESP") then
        local bgui = Instance.new("BillboardGui", v.Head)
        bgui.Name = "RX_ESP"; bgui.AlwaysOnTop = true; bgui.Size = UDim2.new(0, 100, 0, 40); bgui.ExtentsOffset = Vector3.new(0, 3, 0)
        local nametag = Instance.new("TextLabel", bgui)
        nametag.BackgroundTransparency = 1; nametag.Size = UDim2.new(1, 0, 0.5, 0); nametag.Text = "ZOMBIE"; nametag.TextColor3 = Color3.fromRGB(255, 0, 0); nametag.Font = Enum.Font.GothamBold; nametag.TextSize = 12
        local healthBG = Instance.new("Frame", bgui)
        healthBG.BackgroundColor3 = Color3.fromRGB(50, 0, 0); healthBG.Position = UDim2.new(0.1, 0, 0.6, 0); healthBG.Size = UDim2.new(0.8, 0, 0.2, 0); healthBG.BorderSizePixel = 0
        local healthBar = Instance.new("Frame", healthBG)
        healthBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0); healthBar.Size = UDim2.new(1, 0, 1, 0); healthBar.BorderSizePixel = 0
        task.spawn(function()
            local hum = v:WaitForChild("Humanoid")
            while v:IsDescendantOf(workspace) and v:FindFirstChild("Head") and v.Head:FindFirstChild("RX_ESP") do
                local hp = hum.Health / hum.MaxHealth
                healthBar.Size = UDim2.new(math.clamp(hp, 0, 1), 0, 1, 0)
                healthBar.BackgroundColor3 = (hp < 0.3) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                task.wait(0.3)
            end
        end)
    end
end

local function scaleZombieHead(zombie, isBig)
    task.spawn(function()
        task.wait(0.5)
        local head = zombie:FindFirstChild("Head")
        if head then
            if isBig then
                head.Size = Vector3.new(6.5, 6.5, 6.5) 
                head.CanCollide = false
                head.Transparency = 0.1
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                head.CanCollide = true
                head.Transparency = 0
            end
        end
    end)
end

if ZombieFolder then
    ZombieFolder.ChildAdded:Connect(function(child)
        if _G.BigHeadEnabled then scaleZombieHead(child, true) end
    end)
end

